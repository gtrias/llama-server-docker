# Environment Configuration for Llama Server Docker
# Copy this file to .env and customize as needed

# Model Selection
MODEL_NAME=Qwen3-Coder-Next
MODEL_REPO=Qwen/Qwen3-Coder-Next-GGUF
MODEL_FILE=Q4_K_M

# Server Configuration
LLAMA_ARG_HOST=0.0.0.0
LLAMA_ARG_PORT=8080
LLAMA_ARG_JINJA=true

# Sampling Parameters
TEMPERATURE=0.7
TOP_P=1.0
MIN_P=0.01
REPEAT_PENALTY=1.0

# Performance Settings
CTX_SIZE=162144
PARALLEL=2
NGP_LAYERS=-1
KV_UNIFIED=1

# Resource Limits (optional)
MEMORY_LIMIT=50G
MEMORY_RESERVATION=20G

# Traefik reverse proxy (optional)
TRAEFIK_HOST=llama.localhost
# Generate with: htpasswd -nb user password | sed 's/\$/\$\$/g'
TRAEFIK_BASICAUTH=
